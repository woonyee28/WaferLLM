// WSE-3 communication primitives for Prefill.
//
// Queue plan (user input queues 2-7, output queues 2-7 on WSE-3):
//   X mesh-compute : IQ7 / OQ7  (the X pre-shift REUSES this channel — Option A)
//   Y mesh-compute : IQ5 / OQ5
//   reduce c_right : IQ3 / OQ3  (both-ends-to-middle, left half -> root)
//   reduce c_left  : IQ4 / OQ4  (right half -> root)
//   broadcast bd   : IQ6 / OQ6  (merged single color, root fans both ways)
//
// All allreduce / matmul_T reduce use the one-phase both-ends-to-middle scheme.
// Option A: the X pre-shift is a FORWARD shift (offset_step hops) over the
// shared X channel, so there are no dedicated shift colors or queues.
//
// WSE-3 microthread rule (load-bearing): the mesh/shift async DSD ops carry
// EXPLICIT .ut_id (ut0=left-in, ut1=left-out, ut2=right-in, ut3=right-out). An
// async fabric op with no .ut_id defaults to the microthread named by its
// queue id, which on 2.10.0 becomes the module-wide default and makes the
// (synchronous) reduce's back-to-back fabric ops fault with "save into
// ut_instr[N], overwriting".

param comm_params;

param P: i16;

param dim_p_pe: i16;
param seq_len_p_pe: i16;
param ffn_dim_p_pe: i16;
param head_dim_p_pe: i16;  // wyn: per-head GQA tile size

// The X pre-shift and the X mesh-compute both complete on left_matrix_finish_id;
// the kernel's left_matrix_finish task dispatches on its in_preshift flag.
param left_matrix_finish_id: local_task_id;
param right_matrix_finish_id: local_task_id;

const c_right_recv: color = comm_params.c_right_recv;
const c_right_send: color = comm_params.c_right_send;
const c_left_recv: color = comm_params.c_left_recv;
const c_left_send: color = comm_params.c_left_send;

const x_send_color: color = comm_params.x_send_color;
const x_recv_color: color = comm_params.x_recv_color;

const y_send_color: color = comm_params.y_send_color;
const y_recv_color: color = comm_params.y_recv_color;

const bd_color: color = comm_params.bd_color;

var px: i16 = 0;
var py: i16 = 0;

const _dim_dim: i16 = ((dim_p_pe*dim_p_pe) / 4) * 4;
const _seqLen_dim: i16 = ((seq_len_p_pe*dim_p_pe) / 4) * 4;
const _ffnDim_dim: i16 = ((ffn_dim_p_pe*dim_p_pe) / 4) * 4;
const _seqLen_ffnDim: i16 = ((seq_len_p_pe*ffn_dim_p_pe) / 4) * 4;
// wyn: EXACT (no /4*4) — these tiles carry a bare seq_len_p_pe factor, so at seq_len_p_pe==1
// (P==seq_len, e.g. P=128) they are size 1 and the /4*4 SIMD rounding would drop them to 0,
// silently killing the systolic shift. Their fabric DSDs below run non-SIMD to allow extent<4.
const _seqLen_seqLen: i16 = seq_len_p_pe*seq_len_p_pe;
// wyn: per-head GQA tile extents. seqLen_headDim (EXACT, non-SIMD): XQ/XK/XV/output_h & O-proj
// left. dim_headDim (SIMD ok — dim_p_pe*head_dim_p_pe stays a healthy multiple of 4): Q/K/V
// projection right-weight AND O-proj right-weight (head_dim*dim == dim*head_dim).
const _seqLen_headDim: i16 = seq_len_p_pe*head_dim_p_pe;
const _dim_headDim: i16 = ((dim_p_pe*head_dim_p_pe) / 4) * 4;

var root: i16 = 0;

var is_first_px: bool = false;
var is_last_px: bool = false;

const dummy = @zeros([1]f16);

// ---------------------------- Queues -------------------------------------- //

const x_recv_queue_id = @get_input_queue(7);
const x_send_queue_id = @get_output_queue(7);

const y_recv_queue_id = @get_input_queue(5);
const y_send_queue_id = @get_output_queue(5);

const c_right_recv_queue_id = @get_input_queue(3);
const c_right_send_queue_id = @get_output_queue(3);

const c_left_recv_queue_id = @get_input_queue(4);
const c_left_send_queue_id = @get_output_queue(4);

const bd_recv_queue_id = @get_input_queue(6);
const bd_send_queue_id = @get_output_queue(6);

// ---------------------------- DSRs ---------------------------------------- //

const ut0 = @get_ut_id(0);
const ut1 = @get_ut_id(1);
const ut2 = @get_ut_id(2);
const ut3 = @get_ut_id(3);

const left_send_dsr = @get_dsr(dsr_src1, 3);
const left_recv_dsr = @get_dsr(dsr_dest, 3);

const right_send_dsr = @get_dsr(dsr_src1, 4);
const right_recv_dsr = @get_dsr(dsr_dest, 4);

fn init_(_px: i16, _py: i16) void {
    px = _px;
    py = _py;

    root = P / 2;

    if (px == 0) {
        is_first_px = true;
    }

    if (px == P-1) {
        is_last_px = true;
    }
}

var left_matrix_send_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });
var left_matrix_recv_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });

var right_matrix_send_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });
var right_matrix_recv_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });

var right_matrix_send_dsd_seqLen_dim = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_seqLen_dim} -> dummy[i] });
var right_matrix_recv_dsd_seqLen_dim = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_seqLen_dim} -> dummy[i] });

// wyn: per-head score (matmul_T) shifts XK of width head_dim -> seqLen_headDim
var right_matrix_send_dsd_seqLen_headDim = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_seqLen_headDim} -> dummy[i] });
var right_matrix_recv_dsd_seqLen_headDim = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_seqLen_headDim} -> dummy[i] });

// ===================== One-phase both-ends-to-middle reduce ================ //
// Linear both-ends-to-middle: the left half streams right toward root and the
// right half streams left toward root on the interleaved c_right/c_left colors;
// root reduces both arrivals, then fans the result out on the merged bd color.

const mv_right_send = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe,
    .output_queue = c_right_send_queue_id,
});

const mv_right_recv = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe,
    .input_queue = c_right_recv_queue_id,
});

const mv_left_send = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe,
    .output_queue = c_left_send_queue_id,
});

const mv_left_recv = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe,
    .input_queue = c_left_recv_queue_id,
});

const mv_right_send_max = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe,
    .output_queue = c_right_send_queue_id,
});

const mv_right_recv_max = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe,
    .input_queue = c_right_recv_queue_id,
});

const mv_left_send_max = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe,
    .output_queue = c_left_send_queue_id,
});

const mv_left_recv_max = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe,
    .input_queue = c_left_recv_queue_id,
});

const bd_send = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe,
    .output_queue = bd_send_queue_id,
});

const bd_recv = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe,
    .input_queue = bd_recv_queue_id,
});

var vector_buf_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> dummy[i] });
const vector_buf_dsr = @get_dsr(dsr_src1, 2);

fn mv_allreduce_max_x(vector_buf_ptr: [*]f16) void {
    vector_buf_dsd = @set_dsd_base_addr(vector_buf_dsd, vector_buf_ptr);
    @load_to_dsr(vector_buf_dsr, vector_buf_dsd);

    if (px == root) {
        @fmaxh(vector_buf_dsd, mv_right_recv_max, vector_buf_dsr);
        @fmaxh(vector_buf_dsd, mv_left_recv_max, vector_buf_dsr);

        @mov16(bd_send, vector_buf_dsr);
    } else {
        if (is_first_px) {
            @fmovh(mv_right_send_max, vector_buf_dsr);
            @mov16(vector_buf_dsd, bd_recv);
        } else if (is_last_px) {
            @fmovh(mv_left_send_max, vector_buf_dsr);
            @mov16(vector_buf_dsd, bd_recv);
        } else {
            if (px < root) {
                @fmaxh(mv_right_send_max, mv_right_recv_max, vector_buf_dsr);
                @mov16(vector_buf_dsd, bd_recv);
            } else { // px > root
                @fmaxh(mv_left_send_max, mv_left_recv_max, vector_buf_dsr);
                @mov16(vector_buf_dsd, bd_recv);
            }
        }
    }
}

fn mv_allreduce_add_x(vector_buf_ptr: [*]f16) void {
    vector_buf_dsd = @set_dsd_base_addr(vector_buf_dsd, vector_buf_ptr);
    @load_to_dsr(vector_buf_dsr, vector_buf_dsd);

    if (px == root) {
        // First receive from the left half (mv_left), then the right half (mv_right)
        @faddh(vector_buf_dsd, mv_left_recv, vector_buf_dsr);
        @faddh(vector_buf_dsd, mv_right_recv, vector_buf_dsr);

        @mov16(bd_send, vector_buf_dsr);
    } else {
        if (is_first_px) {
            @fmovh(mv_right_send, vector_buf_dsr);
            @mov16(vector_buf_dsd, bd_recv);
        } else if (is_last_px) {
            @fmovh(mv_left_send, vector_buf_dsr);
            @mov16(vector_buf_dsd, bd_recv);
        } else {
            if (px < root) {
                @faddh(mv_right_send, mv_right_recv, vector_buf_dsr);
                @mov16(vector_buf_dsd, bd_recv);
            } else { // px > root
                @faddh(mv_left_send, mv_left_recv, vector_buf_dsr);
                @mov16(vector_buf_dsd, bd_recv);
            }
        }
    }
}

// ===================== RoPE nearest-neighbor pair exchange ================= //
// Used only when head_dim_p_pe==1 (P > head_dim/2, e.g. P=128): a rope pair
// (head dims 2m, 2m+1) then straddles adjacent column-PEs, so each PE swaps its
// single value with its horizontal partner. Reuses the idle reduce colors — the
// interleave already lines up (even c_right_send == odd c_right_recv, even
// c_left_recv == odd c_left_send), so no new colors/routing are needed:
//   even col (pair-lo): send EAST on mv_right_send, recv from EAST on mv_left_recv
//   odd  col (pair-hi): send WEST on mv_left_send,  recv from WEST on mv_right_recv
// Extent = seq_len_p_pe (== 1 whenever rope runs).

var rope_send_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> dummy[i] });
var rope_recv_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> dummy[i] });

fn rope_pair_exchange(val_ptr: [*]f16, recv_ptr: [*]f16) void {
    rope_send_dsd = @set_dsd_base_addr(rope_send_dsd, val_ptr);
    rope_recv_dsd = @set_dsd_base_addr(rope_recv_dsd, recv_ptr);
    @load_to_dsr(vector_buf_dsr, rope_send_dsd);

    if (px % 2 == 0) {
        @fmovh(mv_right_send, vector_buf_dsr);   // send pair-lo EAST to odd partner
        @mov16(rope_recv_dsd, mv_left_recv);     // recv pair-hi from EAST
    } else {
        @fmovh(mv_left_send, vector_buf_dsr);    // send pair-hi WEST to even partner
        @mov16(rope_recv_dsd, mv_right_recv);    // recv pair-lo from WEST
    }
}

// ================= matmul_T reduce (seqLen x seqLen tiles) ================== //

const mv_right_send_seqLen_seqLen = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe * seq_len_p_pe,
    .output_queue = c_right_send_queue_id,
});

const mv_right_recv_seqLen_seqLen = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe * seq_len_p_pe,
    .input_queue = c_right_recv_queue_id,
});

const mv_left_send_seqLen_seqLen = @get_dsd(fabout_dsd, .{
    .extent = seq_len_p_pe * seq_len_p_pe,
    .output_queue = c_left_send_queue_id,
});

const mv_left_recv_seqLen_seqLen = @get_dsd(fabin_dsd, .{
    .extent = seq_len_p_pe * seq_len_p_pe,
    .input_queue = c_left_recv_queue_id,
});

var reduce_send_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * seq_len_p_pe} -> dummy[i] });
var reduce_recv_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * seq_len_p_pe} -> dummy[i] });

const reduce_dest_dsr_1 = @get_dsr(dsr_dest, 1);
const reduce_src0_dsr_1 = @get_dsr(dsr_src0, 1);
const reduce_src1_dsr_1 = @get_dsr(dsr_src1, 1);

const reduce_dest_dsr_2 = @get_dsr(dsr_dest, 2);
const reduce_src0_dsr_2 = @get_dsr(dsr_src0, 2);

fn matmul_T_reduce_add_x(root_: i16, matrix_send_buf_ptr: [*]f16, matrix_recv_buf_ptr: [*]f16) void {

    reduce_send_dsd = @set_dsd_base_addr(reduce_send_dsd, matrix_send_buf_ptr);
    @load_to_dsr(reduce_src0_dsr_1, reduce_send_dsd);

    if (px == root_) {

        reduce_recv_dsd = @set_dsd_base_addr(reduce_recv_dsd, matrix_recv_buf_ptr);
        @load_to_dsr(reduce_dest_dsr_1, reduce_recv_dsd);
        @load_to_dsr(reduce_dest_dsr_2, reduce_recv_dsd);
        @load_to_dsr(reduce_src0_dsr_2, reduce_recv_dsd);

        if (is_first_px) {
            @faddh(reduce_dest_dsr_1, reduce_src0_dsr_1, mv_left_recv_seqLen_seqLen);
        } else if (is_last_px) {
            @faddh(reduce_dest_dsr_1, reduce_src0_dsr_1, mv_right_recv_seqLen_seqLen);
        } else {
            @faddh(reduce_dest_dsr_1, reduce_src0_dsr_1, mv_left_recv_seqLen_seqLen);
            @faddh(reduce_dest_dsr_2, reduce_src0_dsr_2, mv_right_recv_seqLen_seqLen);
        }

    } else {

        @load_to_dsr(reduce_src1_dsr_1, reduce_send_dsd);

        if (is_first_px) {
            @load_to_dsr(reduce_dest_dsr_1, mv_right_send_seqLen_seqLen);
            @fmovh(reduce_dest_dsr_1, reduce_src1_dsr_1);
        } else if (is_last_px) {
            @load_to_dsr(reduce_dest_dsr_1, mv_left_send_seqLen_seqLen);
            @fmovh(reduce_dest_dsr_1, reduce_src1_dsr_1);
        } else {

            if (px < root_) {
                @load_to_dsr(reduce_dest_dsr_1, mv_right_send_seqLen_seqLen);
                @faddh(reduce_dest_dsr_1, mv_right_recv_seqLen_seqLen, reduce_src1_dsr_1);
            } else { // px > root_
                @load_to_dsr(reduce_dest_dsr_1, mv_left_send_seqLen_seqLen);
                @faddh(reduce_dest_dsr_1, mv_left_recv_seqLen_seqLen, reduce_src1_dsr_1);
            }

        }

    }

}

// ========================= Mesh two-hop GEMM ============================== //
// Left matrix travels horizontally on the X channel (IQ7/OQ7); right matrix
// travels vertically on the Y channel (IQ5/OQ5).

const left_matrix_in_dsd_seqLen_dim = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_dim,
    .input_queue = x_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const left_matrix_out_dsd_seqLen_dim = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_dim,
    .output_queue = x_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

// wyn: non-SIMD — _seqLen_seqLen can be < 4 (size 1 at seq_len_p_pe==1)
const left_matrix_in_dsd_seqLen_seqLen = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_seqLen,
    .input_queue = x_recv_queue_id,
});
const left_matrix_out_dsd_seqLen_seqLen = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_seqLen,
    .output_queue = x_send_queue_id,
});

const left_matrix_in_dsd_seqLen_ffnDim = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_ffnDim,
    .input_queue = x_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const left_matrix_out_dsd_seqLen_ffnDim = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_ffnDim,
    .output_queue = x_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

const right_matrix_in_dsd_dim_dim = @get_dsd(fabin_dsd, .{
    .extent = _dim_dim,
    .input_queue = y_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const right_matrix_out_dsd_dim_dim = @get_dsd(fabout_dsd, .{
    .extent = _dim_dim,
    .output_queue = y_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

const right_matrix_in_dsd_seqLen_dim = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_dim,
    .input_queue = y_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const right_matrix_out_dsd_seqLen_dim = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_dim,
    .output_queue = y_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

const right_matrix_in_dsd_ffnDim_dim = @get_dsd(fabin_dsd, .{
    .extent = _ffnDim_dim,
    .input_queue = y_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const right_matrix_out_dsd_ffnDim_dim = @get_dsd(fabout_dsd, .{
    .extent = _ffnDim_dim,
    .output_queue = y_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

// wyn: per-head GQA tile fabric DSDs. left(X channel): seqLen_headDim (O-proj left = output_h).
// right(Y channel): dim_headDim (Q/K/V & O-proj weights) and seqLen_headDim (output right = XV,
// and score-T right = XK).
// wyn: non-SIMD — _seqLen_headDim can be < 4 (size 1 at seq_len_p_pe==1 & head_dim_p_pe==1)
const left_matrix_in_dsd_seqLen_headDim = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_headDim,
    .input_queue = x_recv_queue_id,
});
const left_matrix_out_dsd_seqLen_headDim = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_headDim,
    .output_queue = x_send_queue_id,
});

const right_matrix_in_dsd_dim_headDim = @get_dsd(fabin_dsd, .{
    .extent = _dim_headDim,
    .input_queue = y_recv_queue_id,
    .simd_mode = .{ .simd_max = true }
});
const right_matrix_out_dsd_dim_headDim = @get_dsd(fabout_dsd, .{
    .extent = _dim_headDim,
    .output_queue = y_send_queue_id,
    .simd_mode = .{ .simd_max = true }
});

// wyn: non-SIMD — _seqLen_headDim can be < 4 (size 1 at seq_len_p_pe==1 & head_dim_p_pe==1)
const right_matrix_in_dsd_seqLen_headDim = @get_dsd(fabin_dsd, .{
    .extent = _seqLen_headDim,
    .input_queue = y_recv_queue_id,
});
const right_matrix_out_dsd_seqLen_headDim = @get_dsd(fabout_dsd, .{
    .extent = _seqLen_headDim,
    .output_queue = y_send_queue_id,
});

const left_matrix_out_dsr = @get_dsr(dsr_dest, 5);
const left_matrix_in_dsr = @get_dsr(dsr_src1, 5);

const right_matrix_out_dsr = @get_dsr(dsr_dest, 6);
const right_matrix_in_dsr = @get_dsr(dsr_src1, 6);

fn mm_two_hop_comm(left_matrix_send_buffer_ptr: [*]f16, right_matrix_send_buffer_ptr: [*]f16, left_matrix_recv_buffer_ptr: [*]f16, right_matrix_recv_buffer_ptr: [*]f16, step: i16, Mt: i16, Kt: i16, Nt: i16) void {

    if (step == 0) {
        // wyn: EXACT (was /4*4). For SIMD large tiles Mt*Kt is a multiple of 4 so this is
        // identical; for the small seqLen_seqLen/seqLen_headDim tiles it keeps size-1 shifts
        // from rounding to 0 (matches the now-exact, non-SIMD fabric extents above).
        var _Mt_Kt = Mt * Kt;
        var _Kt_Nt = Kt * Nt;

        left_matrix_send_dsd = @set_dsd_length(left_matrix_send_dsd, @bitcast(u16, _Mt_Kt));
        left_matrix_recv_dsd = @set_dsd_length(left_matrix_recv_dsd, @bitcast(u16, _Mt_Kt));

        right_matrix_send_dsd = @set_dsd_length(right_matrix_send_dsd, @bitcast(u16, _Kt_Nt));
        right_matrix_recv_dsd = @set_dsd_length(right_matrix_recv_dsd, @bitcast(u16, _Kt_Nt));

        if (Kt == dim_p_pe) {
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_dim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_dim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            if (Nt == dim_p_pe) {
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_dim_dim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_dim_dim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            } else if (Nt == ffn_dim_p_pe) {
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_ffnDim_dim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_ffnDim_dim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            } else if (Nt == head_dim_p_pe) {  // wyn: Q/K/V projection -> XQ_h/XK_g/XV_g [seq, head_dim]
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_dim_headDim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_dim_headDim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            }
        } else if (Kt == seq_len_p_pe) {
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_seqLen, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_seqLen, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            if (Nt == dim_p_pe) {
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_seqLen_dim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_seqLen_dim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            } else if (Nt == head_dim_p_pe) {  // wyn: output = probs @ XV_g -> output_h [seq, head_dim]
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_seqLen_headDim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_seqLen_headDim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            }
        } else if (Kt == ffn_dim_p_pe) {
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_ffnDim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_ffnDim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            if (Nt == dim_p_pe) {
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_ffnDim_dim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_ffnDim_dim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            }
        } else if (Kt == head_dim_p_pe) {  // wyn: O-proj h1 += output_h @ Wo_h (contract head_dim, output dim)
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_headDim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_headDim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            if (Nt == dim_p_pe) {
                @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_dim_headDim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
                @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_dim_headDim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
            }
        }
    }

    mm_two_hop_comm_impl(left_matrix_send_buffer_ptr, right_matrix_send_buffer_ptr, left_matrix_recv_buffer_ptr, right_matrix_recv_buffer_ptr);

}

fn mm_two_hop_comm_impl(left_matrix_send_buffer_ptr: [*]f16, right_matrix_send_buffer_ptr: [*]f16, left_matrix_recv_buffer_ptr: [*]f16, right_matrix_recv_buffer_ptr: [*]f16) void {

    left_matrix_send_dsd = @set_dsd_base_addr(left_matrix_send_dsd, left_matrix_send_buffer_ptr);
    right_matrix_send_dsd = @set_dsd_base_addr(right_matrix_send_dsd, right_matrix_send_buffer_ptr);
    left_matrix_recv_dsd = @set_dsd_base_addr(left_matrix_recv_dsd, left_matrix_recv_buffer_ptr);
    right_matrix_recv_dsd = @set_dsd_base_addr(right_matrix_recv_dsd, right_matrix_recv_buffer_ptr);

    @load_to_dsr(left_send_dsr, left_matrix_send_dsd);
    @load_to_dsr(left_recv_dsr, left_matrix_recv_dsd);
    @load_to_dsr(right_send_dsr, right_matrix_send_dsd);
    @load_to_dsr(right_recv_dsr, right_matrix_recv_dsd);

    @mov16(left_matrix_out_dsr, left_send_dsr, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
    @mov16(left_recv_dsr, left_matrix_in_dsr, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});

    @mov16(right_matrix_out_dsr, right_send_dsr, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
    @mov16(right_recv_dsr, right_matrix_in_dsr, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});

}

fn mm_two_hop_comm_T(right_matrix_send_buffer_ptr: [*]f16, right_matrix_recv_buffer_ptr: [*]f16, step: i16) void {

    // wyn: per-head score shifts XK of width head_dim -> seqLen_headDim (== seqLen_dim when n_heads=1)
    if (step == 0) {
        right_matrix_send_dsd = @set_dsd_length(right_matrix_send_dsd, @bitcast(u16, _seqLen_headDim));
        right_matrix_recv_dsd = @set_dsd_length(right_matrix_recv_dsd, @bitcast(u16, _seqLen_headDim));

        @load_to_dsr(right_matrix_in_dsr, right_matrix_in_dsd_seqLen_headDim, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});
        @load_to_dsr(right_matrix_out_dsr, right_matrix_out_dsd_seqLen_headDim, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
    }

    mm_two_hop_comm_T_impl(right_matrix_send_buffer_ptr, right_matrix_recv_buffer_ptr);
}

fn mm_two_hop_comm_T_impl(right_matrix_send_buffer_ptr: [*]f16, right_matrix_recv_buffer_ptr: [*]f16) void {

    right_matrix_send_dsd_seqLen_headDim = @set_dsd_base_addr(right_matrix_send_dsd_seqLen_headDim, right_matrix_send_buffer_ptr);
    right_matrix_recv_dsd_seqLen_headDim = @set_dsd_base_addr(right_matrix_recv_dsd_seqLen_headDim, right_matrix_recv_buffer_ptr);

    @load_to_dsr(right_send_dsr, right_matrix_send_dsd_seqLen_headDim);
    @load_to_dsr(right_recv_dsr, right_matrix_recv_dsd_seqLen_headDim);

    @mov16(right_matrix_out_dsr, right_send_dsr, .{.async=true, .unblock=right_matrix_finish_id, .ut_id=ut3});
    @mov16(right_recv_dsr, right_matrix_in_dsr, .{.async=true, .activate=right_matrix_finish_id, .ut_id=ut2});

}

// ============================ X pre-shift ================================= //
// Forward-only shift over the SHARED X mesh channel (Option A). Reuses the
// left-matrix mesh DSDs / DSRs / queue (IQ7/OQ7) and completes on
// left_matrix_finish_id; the kernel routes that completion to its pre-shift
// driver while in_preshift is set.

fn left_matrix_shift(left_matrix_send_buffer_ptr: [*]f16, left_matrix_recv_buffer_ptr: [*]f16, dim_length: i16, step: i16) void {
    if (step == 0) {
        // wyn: EXACT (was /4*4) so size-1 left tiles (seqLen_seqLen / seqLen_headDim pre-shift)
        // still match their now-exact tile-extent consts in the dispatch below.
        var _dim_length: i16 = dim_length;
        left_matrix_send_dsd = @set_dsd_length(left_matrix_send_dsd, @bitcast(u16, _dim_length));
        left_matrix_recv_dsd = @set_dsd_length(left_matrix_recv_dsd, @bitcast(u16, _dim_length));

        if (_dim_length == _seqLen_dim) {
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_dim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_dim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
        } else if (_dim_length == _seqLen_seqLen) {
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_seqLen, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_seqLen, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
        } else if (_dim_length == _seqLen_ffnDim) {
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_ffnDim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_ffnDim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
        } else if (_dim_length == _seqLen_headDim) {  // wyn: O-proj pre-shift of output_h [seq, head_dim]
            @load_to_dsr(left_matrix_out_dsr, left_matrix_out_dsd_seqLen_headDim, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
            @load_to_dsr(left_matrix_in_dsr, left_matrix_in_dsd_seqLen_headDim, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});
        }
    }

    left_matrix_shift_impl(left_matrix_send_buffer_ptr, left_matrix_recv_buffer_ptr);
}

fn left_matrix_shift_impl(left_matrix_send_buffer_ptr: [*]f16, left_matrix_recv_buffer_ptr: [*]f16) void {

    left_matrix_send_dsd = @set_dsd_base_addr(left_matrix_send_dsd, left_matrix_send_buffer_ptr);
    left_matrix_recv_dsd = @set_dsd_base_addr(left_matrix_recv_dsd, left_matrix_recv_buffer_ptr);

    @load_to_dsr(left_send_dsr, left_matrix_send_dsd);
    @load_to_dsr(left_recv_dsr, left_matrix_recv_dsd);

    @mov16(left_matrix_out_dsr, left_send_dsr, .{.async=true, .unblock=left_matrix_finish_id, .ut_id=ut1});
    @mov16(left_recv_dsr, left_matrix_in_dsr, .{.async=true, .activate=left_matrix_finish_id, .ut_id=ut0});

}

comptime {
    @initialize_queue(x_recv_queue_id, .{.color = x_recv_color});
    @initialize_queue(x_send_queue_id, .{.color = x_send_color});

    @initialize_queue(y_recv_queue_id, .{.color = y_recv_color});
    @initialize_queue(y_send_queue_id, .{.color = y_send_color});

    @initialize_queue(c_right_recv_queue_id, .{.color = c_right_recv});
    @initialize_queue(c_right_send_queue_id, .{.color = c_right_send});

    @initialize_queue(c_left_recv_queue_id, .{.color = c_left_recv});
    @initialize_queue(c_left_send_queue_id, .{.color = c_left_send});

    @initialize_queue(bd_recv_queue_id, .{.color = bd_color});
    @initialize_queue(bd_send_queue_id, .{.color = bd_color});
}
