param memcpy_params;
param comm_params;

param P: i16;
param dim_p_pe: i16;
param seq_len_p_pe: i16;
param ffn_dim_p_pe: i16;
// wyn: GQA head params (derived in compile.py, forwarded from layout.csl)
param pes_p_head: i16;
param pes_p_kv_head: i16;
param head_dim_p_pe: i16;
param kv_dim_p_pe: i16;
// wyn: FFN-only program (disaggregated layer): 1 => skip attention, input X is resid_mid.
param ffn_only: i16;
// wyn: end

// wyn: Llama-3 rms_norm_eps = 1e-5 (was 1e-6). Matters at the BOS token, whose RMSNorm variance
// is ~1e-5 — comparable to eps — so a wrong eps skews its norm factor ~15-30% (massive-activation dims).
const eps: f16 = 0.00001;
// wyn: causal-mask fill value (in fp16, exp(−10000) underflows to exactly 0)
const neg_inf: f16 = -1.0e4;
// wyn: end
var alpha: f16 = 0.0;

const _dim_p_pe: i16 = (dim_p_pe / 2) * 2;
// wyn: split model width (RMSNorm mean divisor) from attention head width (score scaling).
// For single-head configs head_dim_p_pe*P == dim_p_pe*P, so existing configs are unchanged.
const model_dim: f16 = @as(f16, dim_p_pe * P);
const head_dim: f16 = @as(f16, head_dim_p_pe * P);
// wyn: end

// wyn: GQA head-sequential loop state. n_heads query heads, group = query heads per KV head.
// The attention stages (flags for project/rope/score/softmax/output/O-proj) run once per head;
// head_idx is the current query head, kv_head_idx = head_idx / group is the KV head it attends to.
const n_heads: i16 = P / pes_p_head;
const group: i16 = pes_p_kv_head / pes_p_head;   // = n_heads / n_kv_heads
var head_idx: i16 = 0;
var kv_head_idx: i16 = 0;
// wyn: end

var root: i16 = P / 2;
var reduce_root: i16 = 0;
const seq_len_p_pe_2: i16 = seq_len_p_pe * 2;

const left_matrix_finish_id: local_task_id = @get_local_task_id(19);
const right_matrix_finish_id: local_task_id = @get_local_task_id(20);
const next_step_id: local_task_id = @get_local_task_id(26); // 24 is reserved when memcpy is imported
const two_hop_comm_finish_id: local_task_id = @get_local_task_id(25);

const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);
const math_lib = @import_module("<math>");
const layout_mod = @import_module("<layout>");
const comm_mod = @import_module("comm_lib/comm_pe.csl", .{
    .comm_params = comm_params,
    .P = P, .dim_p_pe = dim_p_pe, .seq_len_p_pe = seq_len_p_pe, .ffn_dim_p_pe = ffn_dim_p_pe,
    .head_dim_p_pe = head_dim_p_pe,  // wyn: per-head GQA tile size
    .left_matrix_finish_id = left_matrix_finish_id,
    .right_matrix_finish_id = right_matrix_finish_id,
});

var px: i16 = 0;
var py: i16 = 0;

var Mt: i16 = 0;
var Kt: i16 = 0;
var Nt: i16 = 0;

var left_dim_length: i16 = 0;
var right_dim_length: i16 = 0;

// X pre-shift state (Option A: forward-only over the shared X mesh channel).
// offset_step is the forward hop count per row (= the reference MeshGEMM pre_n):
//   odd  py: +(py+1)/2          (forward, unchanged)
//   even py: forward (P - py/2) (the upstream reverse py/2 folded to forward)
// For even P this matches the upstream reverse-shift buffer parity, so the
// xk/xv/z2 "reuse the already-shifted X_norm/Z_norm" optimisation is preserved.
var in_preshift: bool = false;
var pre_remaining: i16 = 0;
var shift_round: i16 = 0;

var offset_step: i16 = 0;
var current_offset: i16 = 0;

var step: i16 = 0;

var cos_val: f16 = 0.0;
var sin_val: f16 = 0.0;

var is_T_matmul: bool = false;

const timestamp = @import_module("<time>");
// starting time of H2D/D2H
var tscStartBuffer = @zeros([timestamp.tsc_size_words]u16);
// ending time of H2D/D2H
var tscEndBuffer = @zeros([timestamp.tsc_size_words]u16);

var time_buf_f32 = @zeros([3]f32);
var ptr_time_memcpy: [*]f32 = &time_buf_f32;

var tscRefBuffer = @zeros([timestamp.tsc_size_words]u16);
var time_ref_f32 = @zeros([2]f32);
var ptr_time_ref: [*]f32 = &time_ref_f32;

fn init_task() void {
    timestamp.enable_tsc();

    px = @as(i16, layout_mod.get_x_coord());
    py = @as(i16, layout_mod.get_y_coord());

    // * offset_step: forward pre-shift hop count AND offset in the 2-hop reduce order
    //
    // wyn: offset_step PARITY was the attention bug (13 Jul, P=8 sim). Each pre-shift hop
    // swaps the left send/recv buffers, so after a projection the shifted tile sits in a
    // buffer determined by offset_step's parity -- and xk_matmul/xv_matmul used to hardcode
    // which buffer that was. Measured: XK exact for even offset_step (py 0,3,4,7 at P=8),
    // garbage for odd (py 1,2,5,6). See the note in xk_matmul and devlogs/13July26.md PART 6.
    if (py == 0) {
        offset_step = 0;
    } else if (py % 2 == 0) {
        offset_step = P - (py / 2);
    } else {
        offset_step = (py + 1) / 2;
    }

    comm_mod.init_(px, py);

    alpha = 1.0 / @as(f16, math_lib.sqrt(head_dim));

    sys_mod.unblock_cmd_stream();
}

// * X: input
var X_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_X: [*]f16 = &X_tile;
var X_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> X_tile[i] });

// * W: RMSNorm weights
var W_tile: [dim_p_pe]f16 = @zeros([dim_p_pe]f16);
var ptr_W: [*]f16 = &W_tile;
var W_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{dim_p_pe} -> W_tile[i] });

// wyn: second RMSNorm weight (post_attention_layernorm), used by rmsnorm_z (pre-FFN norm)
var W2_tile: [dim_p_pe]f16 = @zeros([dim_p_pe]f16);
var ptr_W2: [*]f16 = &W2_tile;
// wyn: end

// * Q_weight, K_weight, V_weight: QKV weights input
var Q_weight_tile: [dim_p_pe * dim_p_pe]f16 = @zeros([dim_p_pe * dim_p_pe]f16);
var ptr_Q_weight: [*]f16 = &Q_weight_tile;

// wyn: rectangular K/V weights — hold n_kv_heads head-slices of [dim_p_pe*head_dim_p_pe]
// (total dim_p_pe*kv_dim_p_pe), vs the full dim_p_pe*dim_p_pe for Q.
var K_weight_tile: [dim_p_pe * kv_dim_p_pe]f16 = @zeros([dim_p_pe * kv_dim_p_pe]f16);
var ptr_K_weight: [*]f16 = &K_weight_tile;

var V_weight_tile: [dim_p_pe * kv_dim_p_pe]f16 = @zeros([dim_p_pe * kv_dim_p_pe]f16);
var ptr_V_weight: [*]f16 = &V_weight_tile;
// wyn: end

var freqs_sin: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_freqs_sin: [*]f16 = &freqs_sin;

var freqs_cos: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_freqs_cos: [*]f16 = &freqs_cos;

var O_weight_tile: [dim_p_pe * dim_p_pe]f16 = @zeros([dim_p_pe * dim_p_pe]f16);
var ptr_O_weight: [*]f16 = &O_weight_tile;

var UP_weight_tile: [dim_p_pe * ffn_dim_p_pe]f16 = @zeros([dim_p_pe * ffn_dim_p_pe]f16);
var ptr_UP_weight: [*]f16 = &UP_weight_tile;

var GATE_weight_tile: [dim_p_pe * ffn_dim_p_pe]f16 = @zeros([dim_p_pe * ffn_dim_p_pe]f16);
var ptr_GATE_weight: [*]f16 = &GATE_weight_tile;

var DOWN_weight_tile: [dim_p_pe * ffn_dim_p_pe]f16 = @zeros([dim_p_pe * ffn_dim_p_pe]f16);
var ptr_DOWN_weight: [*]f16 = &DOWN_weight_tile;

// ************************ Middle Results ************************ //

var X_norm_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_X_norm: [*]f16 = &X_norm_tile;

// wyn: pristine copy of X_norm. Each head's projection pre-shifts X_norm in place, so we restore
// this backup before every head — all heads then project the SAME input through their own weights.
var X_norm_backup: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_X_norm_backup: [*]f16 = &X_norm_backup;   // wyn: DEBUG export (pristine rmsnorm_x output)

// * XQ, XK, XV: per-head QKV in prefill. One head fills the mesh: head_dim across all P
// columns (head_dim_p_pe per PE), so each tile is [seq_len_p_pe * head_dim_p_pe].
var XQ_tile: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_XQ: [*]f16 = &XQ_tile;
var XQ_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> XQ_tile[i] });

// wyn: DEBUG — head-0 XQ snapshots (pre-rope = projection, post-rope = rope-NN output)
var xq_proj_dbg: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_xq_proj_dbg: [*]f16 = &xq_proj_dbg;
var xq_proj_dbg_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> xq_proj_dbg[i] });
var xq_rope_dbg: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_xq_rope_dbg: [*]f16 = &xq_rope_dbg;
var xq_rope_dbg_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> xq_rope_dbg[i] });

var XK_tile: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_XK: [*]f16 = &XK_tile;
var XK_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> XK_tile[i] });

var XV_tile: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_XV: [*]f16 = &XV_tile;
var XV_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> XV_tile[i] });

// wyn: rope pair partner received from the horizontal neighbor (head_dim_p_pe==1 path only)
var rope_partner: [seq_len_p_pe]f16 = @zeros([seq_len_p_pe]f16);
var ptr_rope_partner: [*]f16 = &rope_partner;

var local_sum: [seq_len_p_pe]f16 = @zeros([seq_len_p_pe]f16);
var ptr_local_sum: [*]f16 = &local_sum;
var local_sum_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> local_sum[i] });

var sum: f16 = 0.0;

var local_max: [seq_len_p_pe]f16 = @zeros([seq_len_p_pe]f16);
var ptr_local_max: [*]f16 = &local_max;
var local_max_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> local_max[i] });

// wyn: per-head attention output [seq_len_p_pe * head_dim_p_pe]; each head's result is fed
// through its O-weight slice and accumulated into h1 (see o-projection), so no [seq,dim] concat.
var output_tile: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_output: [*]f16 = &output_tile;
var output_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * head_dim_p_pe} -> output_tile[i] });

var X_tmp_1: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_X_tmp_1: [*]f16 = &X_tmp_1;
var X_tmp_1_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_dim_p_pe / 2} -> X_tmp_1[i] });

var X_tmp_2: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_X_tmp_2: [*]f16 = &X_tmp_2;
var X_tmp_2_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_dim_p_pe / 2} -> X_tmp_2[i] });

var X_tmp_3: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_X_tmp_3: [*]f16 = &X_tmp_3;
var X_tmp_3_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_dim_p_pe / 2} -> X_tmp_3[i] });

var X_tmp_4: [_dim_p_pe / 2]f16 = @zeros([_dim_p_pe / 2]f16);
var ptr_X_tmp_4: [*]f16 = &X_tmp_4;
var X_tmp_4_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{_dim_p_pe / 2} -> X_tmp_4[i] });

var score: [seq_len_p_pe * seq_len_p_pe]f16 = @zeros([seq_len_p_pe * seq_len_p_pe]f16);
var ptr_score: [*]f16 = &score;
var score_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * seq_len_p_pe} -> score[i] });

// wyn: DEBUG — head-0 raw score (Q.K^T, pre-softmax) snapshot for attention validation
var score_dbg: [seq_len_p_pe * seq_len_p_pe]f16 = @zeros([seq_len_p_pe * seq_len_p_pe]f16);
var ptr_score_dbg: [*]f16 = &score_dbg;
var score_dbg_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * seq_len_p_pe} -> score_dbg[i] });

// wyn: DEBUG — head-0 trace of the XK tile each PE actually multiplies at systolic step s.
// This is what localised the attention bug: its step-0 slice (before any score shift) shows
// XK already corrupt for odd-offset_step rows, which cleared both the reduce and the score
// matmul and pointed at the K projection. Keep it until attention is validated end to end;
// the host side reads it in launch_sim_attn.py ("K projection sanity" check).
var xk_trace: [P * seq_len_p_pe * head_dim_p_pe]f16 = @zeros([P * seq_len_p_pe * head_dim_p_pe]f16);
var ptr_xk_trace: [*]f16 = &xk_trace;

// wyn: DEBUG — head-0 inputs to output_matmul, snapshotted where it consumes them. The raw
// score is validated (cos 0.999999) but attention output is still wrong, so the two never-
// checked stages are the softmax/causal-mask output (probs) and the V projection.
var probs_dbg: [seq_len_p_pe * seq_len_p_pe]f16 = @zeros([seq_len_p_pe * seq_len_p_pe]f16);
var ptr_probs_dbg: [*]f16 = &probs_dbg;
var xv_dbg: [seq_len_p_pe * head_dim_p_pe]f16 = @zeros([seq_len_p_pe * head_dim_p_pe]f16);
var ptr_xv_dbg: [*]f16 = &xv_dbg;

var h1_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_h1: [*]f16 = &h1_tile;
var h1_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> h1_tile[i] });

var h2_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_h2: [*]f16 = &h2_tile;
var h2_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> h2_tile[i] });

var z1_tile: [seq_len_p_pe * ffn_dim_p_pe]f16 = @zeros([seq_len_p_pe * ffn_dim_p_pe]f16);
var ptr_z1: [*]f16 = &z1_tile;
var z1_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * ffn_dim_p_pe} -> z1_tile[i] });

var z2_tile: [seq_len_p_pe * ffn_dim_p_pe]f16 = @zeros([seq_len_p_pe * ffn_dim_p_pe]f16);
var ptr_z2: [*]f16 = &z2_tile;
var z2_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * ffn_dim_p_pe} -> z2_tile[i] });

var z3_tile: [seq_len_p_pe * ffn_dim_p_pe]f16 = @zeros([seq_len_p_pe * ffn_dim_p_pe]f16);
var ptr_z3: [*]f16 = &z3_tile;
var z3_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * ffn_dim_p_pe} -> z3_tile[i] });

var Z_norm_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_Z_norm: [*]f16 = &Z_norm_tile;

var Z_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_Z: [*]f16 = &Z_tile;
var Z_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> Z_tile[i] });

// wyn: post-attention residual (Z = X + attn, before FFN) = Llama resid_mid. Snapshotted in
// z_add and read back by the host to validate attention independently of the FFN.
var Z_mid_tile: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_Z_mid: [*]f16 = &Z_mid_tile;
var Z_mid_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> Z_mid_tile[i] });

var swap_ptr: [*]f16;
var ptr_left_matrix_send: [*]f16;
var ptr_left_matrix_recv: [*]f16;
var ptr_right_matrix_send: [*]f16;
var ptr_right_matrix_recv: [*]f16;
var ptr_out_matrix: [*]f16;

var seqLen_dim_tmp: [seq_len_p_pe * dim_p_pe]f16 = @zeros([seq_len_p_pe * dim_p_pe]f16);
var ptr_seqLen_dim_tmp: [*]f16 = &seqLen_dim_tmp;
var seqLen_dim_tmp_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * dim_p_pe} -> seqLen_dim_tmp[i] });

var seqLen_seqLen_tmp: [seq_len_p_pe * seq_len_p_pe]f16 = @zeros([seq_len_p_pe * seq_len_p_pe]f16);
var ptr_seqLen_seqLen_tmp: [*]f16 = &seqLen_seqLen_tmp;
var seqLen_seqLen_tmp_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe * seq_len_p_pe} -> seqLen_seqLen_tmp[i] });

var dim_ffnDim_tmp: [dim_p_pe * ffn_dim_p_pe]f16 = @zeros([dim_p_pe * ffn_dim_p_pe]f16);

var seqLen_ffnDim_tmp: [seq_len_p_pe * ffn_dim_p_pe]f16 = @zeros([seq_len_p_pe * ffn_dim_p_pe]f16);

var dim_dim_tmp: [dim_p_pe * dim_p_pe]f16 = @zeros([dim_p_pe * dim_p_pe]f16);

const dummy = @zeros([1]f16);

var left_matrix_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });
var right_matrix_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });
var out_matrix_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> dummy[i] });

var seqLen_dsd_1 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> dummy[i] });
var seqLen_dsd_2 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{seq_len_p_pe} -> dummy[i] });

const comp_dest_dsr_1 = @get_dsr(dsr_dest, 1);
const comp_src0_dsr_1 = @get_dsr(dsr_src0, 1);
const comp_src1_dsr_1 = @get_dsr(dsr_src1, 1);

const comp_dest_dsr_2 = @get_dsr(dsr_dest, 2);
const comp_src0_dsr_2 = @get_dsr(dsr_src0, 2);
const comp_src1_dsr_2 = @get_dsr(dsr_src1, 2);

// Forward-only X pre-shift (Option A). Each hop swaps so the just-received tile
// becomes the next send, runs over the shared X mesh channel, and completes on
// left_matrix_finish_id — which, while in_preshift is set, dispatches back here.
//
// wyn: this routine is CORRECT for any hop count -- traced 13 Jul. Each hop swaps then
// shifts, so the working tile always lands in recv, and matmul_compute's own swap then
// puts it back in send. Verified for offset_step = 0, odd and even.
// BUT it leaves the tile in a buffer whose identity depends on offset_step PARITY, and
// callers that hardcode which buffer to read (xk_matmul/xv_matmul) get it wrong for one
// parity. See the note on xk_matmul.
fn left_matrix_shift_callback() void {
    if (pre_remaining > 0) {
        pre_remaining -= 1;

        swap_ptr = ptr_left_matrix_send;
        ptr_left_matrix_send = ptr_left_matrix_recv;
        ptr_left_matrix_recv = swap_ptr;

        comm_mod.left_matrix_shift(ptr_left_matrix_send, ptr_left_matrix_recv, left_dim_length, shift_round);
        shift_round += 1;

    } else {
        in_preshift = false;
        step = 0;
        matmul_compute();
    }
}

task left_matrix_finish() void {
    @block(left_matrix_finish_id);
    if (in_preshift) {
        left_matrix_shift_callback();
    } else {
        @unblock(two_hop_comm_finish_id);
    }
}

task right_matrix_finish() void {
    @block(right_matrix_finish_id);
    @activate(two_hop_comm_finish_id);
}

task two_hop_comm_finish() void {
    @block(two_hop_comm_finish_id);
    @unblock(next_step_id);
}

task next_step() void {
    @block(next_step_id);
    if (is_T_matmul) {
        matmul_T_compute();
    } else {
        matmul_compute();
    }
}

fn matmul_map_func(curR: f16) void {
    @fmach(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1, curR);
}

fn matmul_T_reduce_add() void {

    current_offset = @as(i16, math_lib.floor_f16(@as(f16, (offset_step + step - 1)) / @as(f16, P)));
    current_offset = (offset_step + step - 1) - current_offset * P;

    if (current_offset == 0) {
        reduce_root = 0;
    } else if (current_offset <= root) {
        reduce_root = 2 * current_offset - 1;
    } else {
        reduce_root = 2 * (P - current_offset);
    }

    // wyn: NOT the bug -- do not "fix" this again. Swapping it for the fixed-root
    // mv_allreduce_add_x (verified correct; rmsnorm/softmax rely on it) left the
    // even-co/odd-co fingerprint identical on the P=8 sim, which proves the sum is fine.
    // The score matmul is innocent too: at score step 0, before any shift, XK is already
    // corrupt for odd-offset_step rows. Root cause was the K projection reading the wrong
    // buffer -- see the note in xk_matmul. "Only even co is right" just means "the row
    // currently holds one of the keys whose projection survived".
    comm_mod.matmul_T_reduce_add_x(reduce_root, ptr_seqLen_seqLen_tmp, ptr_score);

    @load_to_dsr(comp_dest_dsr_1, seqLen_seqLen_tmp_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);
}

fn matmul_T_compute() void {

    swap_ptr = ptr_right_matrix_send;
    ptr_right_matrix_send = ptr_right_matrix_recv;
    ptr_right_matrix_recv = swap_ptr;

    if (step < P) {

        @unblock(two_hop_comm_finish_id);
        comm_mod.mm_two_hop_comm_T(ptr_right_matrix_send, ptr_right_matrix_recv, step);

        left_matrix_dsd = @set_dsd_base_addr(left_matrix_dsd, ptr_left_matrix_send);
        right_matrix_dsd = @set_dsd_base_addr(right_matrix_dsd, ptr_right_matrix_send);

        // wyn: DEBUG snapshot the K chunk this PE multiplies at step `step` (head 0 only).
        if (head_idx == 0) {
            for (@range(i16, seq_len_p_pe * head_dim_p_pe)) |i| {
                xk_trace[step * seq_len_p_pe * head_dim_p_pe + i] = ptr_right_matrix_send[i];
            }
        }

        for (@range(i16, Kt)) |k| {

            out_matrix_dsd = @set_dsd_base_addr(out_matrix_dsd, ptr_out_matrix);

            @load_to_dsr(comp_dest_dsr_1, out_matrix_dsd, .{ .save_address = true });
            @load_to_dsr(comp_src0_dsr_1, out_matrix_dsd, .{ .save_address = true });
            @load_to_dsr(comp_src1_dsr_1, left_matrix_dsd, .{ .save_address = false });
            @map(matmul_map_func, right_matrix_dsd);

            left_matrix_dsd = @increment_dsd_offset(left_matrix_dsd, Mt, f16);
            right_matrix_dsd = @increment_dsd_offset(right_matrix_dsd, Nt, f16);

        }

        step += 1;
        matmul_T_reduce_add();
        @activate(next_step_id);

    } else {
        step = 0;

        prefill_struct();
    }
}

fn matmul_compute() void {

    swap_ptr = ptr_left_matrix_send;
    ptr_left_matrix_send = ptr_left_matrix_recv;
    ptr_left_matrix_recv = swap_ptr;

    swap_ptr = ptr_right_matrix_send;
    ptr_right_matrix_send = ptr_right_matrix_recv;
    ptr_right_matrix_recv = swap_ptr;
    
    if (step < P) {

        comm_mod.mm_two_hop_comm(ptr_left_matrix_send, ptr_right_matrix_send, ptr_left_matrix_recv, ptr_right_matrix_recv, step, Mt, Kt, Nt);

        left_matrix_dsd = @set_dsd_base_addr(left_matrix_dsd, ptr_left_matrix_send);
        right_matrix_dsd = @set_dsd_base_addr(right_matrix_dsd, ptr_right_matrix_send);

        for (@range(i16, Kt)) |k| {

            out_matrix_dsd = @set_dsd_base_addr(out_matrix_dsd, ptr_out_matrix);

            @load_to_dsr(comp_dest_dsr_1, out_matrix_dsd, .{ .save_address = true });
            @load_to_dsr(comp_src0_dsr_1, out_matrix_dsd, .{ .save_address = true });
            @load_to_dsr(comp_src1_dsr_1, left_matrix_dsd, .{ .save_address = false });
            @map(matmul_map_func, right_matrix_dsd);

            left_matrix_dsd = @increment_dsd_offset(left_matrix_dsd, Mt, f16);
            right_matrix_dsd = @increment_dsd_offset(right_matrix_dsd, Nt, f16);

        }

        step += 1;

        @activate(next_step_id);

    } else {
        step = 0;

        prefill_struct();
    }

}


fn rmsnorm_x() void {

    @load_to_dsr(comp_dest_dsr_1, seqLen_dim_tmp_dsd);
    @load_to_dsr(comp_src0_dsr_1, X_dsd);
    @load_to_dsr(comp_src1_dsr_1, X_dsd);
    @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);

    // Clearing
    @load_to_dsr(comp_dest_dsr_2, local_sum_dsd, .{ .save_address = false });
    @fmovh(comp_dest_dsr_2, 0.0);

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_seqLen_dim_tmp);

    @load_to_dsr(comp_src0_dsr_2, local_sum_dsd, .{ .save_address = false });
    @load_to_dsr(comp_src1_dsr_2, seqLen_dsd_1, .{ .save_address = true });
    
    for (@range(i16, dim_p_pe)) |i| {
        @faddh(comp_dest_dsr_2, comp_src0_dsr_2, comp_src1_dsr_2);
    }

    comm_mod.mv_allreduce_add_x(ptr_local_sum);

    for (@range(i16, seq_len_p_pe)) |i| {
        sum = ptr_local_sum[i];
        // wyn: RMSNorm mean is over the full model dim, not the attention head_dim
        sum = sum / model_dim;
        // wyn: end
        ptr_local_sum[i] = 1.0 / math_lib.sqrt_f16(sum + eps);
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_X_norm);
    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_X);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true });
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_2, .{ .save_address = true });

    for (@range(i16, dim_p_pe)) |i| {
        @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, W_tile[i]);
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_X_norm);
    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_X_norm);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true });
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_2, .{ .save_address = true });

    // wyn: local_sum has only seq_len_p_pe entries; local_sum[i] over dim_p_pe read OOB (worked by
    // luck in the attention compile). seq_len_p_pe==1, so all dims share one norm factor — read once.
    var nf: f16 = ptr_local_sum[0];
    for (@range(i16, dim_p_pe)) |i| {
        @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, nf);
    }

    // wyn: stash pristine X_norm for the per-head loop to restore before each head's pre-shift
    for (@range(i16, seq_len_p_pe * dim_p_pe)) |i| {
        X_norm_backup[i] = X_norm_tile[i];
    }

    prefill_struct();
}

fn xq_matmul() void {

    // wyn: restore pristine X_norm — the previous head's pre-shift/projections left it shifted in place
    for (@range(i16, seq_len_p_pe * dim_p_pe)) |i| {
        X_norm_tile[i] = X_norm_backup[i];
    }

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, XQ_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    ptr_left_matrix_send = &seqLen_dim_tmp;
    ptr_left_matrix_recv = &X_norm_tile;

    ptr_right_matrix_send = &dim_dim_tmp;
    // wyn: project only head_idx's slice of Q -> XQ_h [seq, head_dim]. Q weight is head-major:
    // head h at element offset h * (dim_p_pe * head_dim_p_pe).
    ptr_right_matrix_recv = @ptrcast([*]f16, &Q_weight_tile[head_idx * dim_p_pe * head_dim_p_pe]);

    ptr_out_matrix = &XQ_tile;

    Mt = seq_len_p_pe;
    Kt = dim_p_pe;
    Nt = head_dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    // wyn: pre-shift X_norm every head (mirrors the single-head structure so each head re-primes
    // the X comm channel — skipping it on later heads deadlocked the matmul chain).
    in_preshift = true;
    pre_remaining = offset_step;
    shift_round = 0;
    left_matrix_shift_callback();
}

fn xk_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, XK_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    // wyn: THE ATTENTION BUG (13 Jul, found on the P=8 sim). This used to hardcode
    //     ptr_left_matrix_send = &seqLen_dim_tmp;  ptr_left_matrix_recv = &X_norm_tile;
    // i.e. it assumed xq_matmul left the shifted X in X_norm_tile. It does not: the
    // pre-shift does offset_step swaps and matmul_compute does P+1 more, so the tile
    // ends in X_norm_tile only when offset_step is EVEN; for odd offset_step it is in
    // seqLen_dim_tmp and this projected a stale buffer. Measured: XK rows were exact
    // for py with even offset_step (0,3,4,7 at P=8) and garbage for odd (1,2,5,6),
    // which downstream looked like "the score reduce is wrong on odd co".
    // Fix: don't name the buffer -- matmul_compute leaves the working tile in
    // ptr_left_matrix_send, and swaps on entry, so just swap it into recv here.
    swap_ptr = ptr_left_matrix_send;
    ptr_left_matrix_send = ptr_left_matrix_recv;
    ptr_left_matrix_recv = swap_ptr;

    ptr_right_matrix_send = &dim_dim_tmp;
    // wyn: project KV head kv_head_idx's slice of K -> XK_g [seq, head_dim]
    ptr_right_matrix_recv = @ptrcast([*]f16, &K_weight_tile[kv_head_idx * dim_p_pe * head_dim_p_pe]);

    ptr_out_matrix = &XK_tile;

    Mt = seq_len_p_pe;
    Kt = dim_p_pe;
    Nt = head_dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    matmul_compute(); // reuses the X_norm xq_matmul already shifted (see buffer note above)
}

fn xv_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, XV_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    // wyn: same buffer-parity bug as xk_matmul -- see the note there. Reuse whatever
    // buffer xk_matmul's matmul_compute left the shifted X in rather than naming one.
    swap_ptr = ptr_left_matrix_send;
    ptr_left_matrix_send = ptr_left_matrix_recv;
    ptr_left_matrix_recv = swap_ptr;

    ptr_right_matrix_send = &dim_dim_tmp;
    // wyn: project KV head kv_head_idx's slice of V -> XV_g [seq, head_dim]
    ptr_right_matrix_recv = @ptrcast([*]f16, &V_weight_tile[kv_head_idx * dim_p_pe * head_dim_p_pe]);

    ptr_out_matrix = &XV_tile;

    Mt = seq_len_p_pe;
    Kt = dim_p_pe;
    Nt = head_dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    matmul_compute(); // reuses the X_norm xq_matmul already shifted (see buffer note above)
}

// wyn: head_dim_p_pe==1 rope — the pair's other dim lives on the neighbor column-PE, so swap
// values over the reduce fabric then apply the SAME reflection the local loop does:
//   even col holds pair-lo a: a' = partner(b)*cos - a*sin
//   odd  col holds pair-hi b: b' = partner(a)*cos + b*sin
// Both PEs of a pair share one angle -> freqs_*[0] (seq_len_p_pe==1 whenever rope runs).
fn rope_nn(x_ptr: [*]f16) void {
    comm_mod.rope_pair_exchange(x_ptr, ptr_rope_partner);
    var c: f16 = freqs_cos[0];
    var s: f16 = freqs_sin[0];
    if (px % 2 == 0) {
        for (@range(i16, seq_len_p_pe)) |j| {
            x_ptr[j] = rope_partner[j] * c - x_ptr[j] * s;
        }
    } else {
        for (@range(i16, seq_len_p_pe)) |j| {
            x_ptr[j] = rope_partner[j] * c + x_ptr[j] * s;
        }
    }
}

fn xq_rope() void {

    if (head_dim_p_pe == 1) {
        if (head_idx == 0) { @fmovh(xq_proj_dbg_dsd, XQ_dsd); }   // wyn: DEBUG pre-rope
        rope_nn(ptr_XQ);
        if (head_idx == 0) { @fmovh(xq_rope_dbg_dsd, XQ_dsd); }   // wyn: DEBUG post-rope
        prefill_struct();
        return;
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_XQ);

    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_XQ);
    seqLen_dsd_2 = @increment_dsd_offset(seqLen_dsd_2, seq_len_p_pe, f16);

    // wyn: rope rotates this PE's head_dim_p_pe columns -> head_dim_p_pe/2 adjacent pairs
    for (@range(i16, head_dim_p_pe/2)) |i| {
        cos_val = freqs_cos[i];
        sin_val = freqs_sin[i];

        if (i != 0) {
            seqLen_dsd_1 = @increment_dsd_offset(seqLen_dsd_1, seq_len_p_pe_2, f16);
            seqLen_dsd_2 = @increment_dsd_offset(seqLen_dsd_2, seq_len_p_pe_2, f16);
        }

        @fmulh(X_tmp_1_dsd, seqLen_dsd_2, cos_val);
        @fmulh(X_tmp_2_dsd, seqLen_dsd_1, sin_val);
        @fmulh(X_tmp_3_dsd, seqLen_dsd_1, cos_val);
        @fmulh(X_tmp_4_dsd, seqLen_dsd_2, sin_val);

        @fsubh(seqLen_dsd_1, X_tmp_1_dsd, X_tmp_2_dsd);
        @faddh(seqLen_dsd_2, X_tmp_3_dsd, X_tmp_4_dsd);
    }

    prefill_struct();
}

fn xk_rope() void {

    if (head_dim_p_pe == 1) {
        rope_nn(ptr_XK);
        prefill_struct();
        return;
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_XK);

    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_XK);
    seqLen_dsd_2 = @increment_dsd_offset(seqLen_dsd_2, seq_len_p_pe, f16);

    // wyn: rope rotates this PE's head_dim_p_pe columns -> head_dim_p_pe/2 adjacent pairs
    for (@range(i16, head_dim_p_pe/2)) |i| {
        cos_val = freqs_cos[i];
        sin_val = freqs_sin[i];

        if (i != 0) {
            seqLen_dsd_1 = @increment_dsd_offset(seqLen_dsd_1, seq_len_p_pe_2, f16);
            seqLen_dsd_2 = @increment_dsd_offset(seqLen_dsd_2, seq_len_p_pe_2, f16);
        }

        @fmulh(X_tmp_1_dsd, seqLen_dsd_2, cos_val);
        @fmulh(X_tmp_2_dsd, seqLen_dsd_1, sin_val);
        @fmulh(X_tmp_3_dsd, seqLen_dsd_1, cos_val);
        @fmulh(X_tmp_4_dsd, seqLen_dsd_2, sin_val);

        @fsubh(seqLen_dsd_1, X_tmp_1_dsd, X_tmp_2_dsd);
        @faddh(seqLen_dsd_2, X_tmp_3_dsd, X_tmp_4_dsd);
    }

    prefill_struct();
}

fn score_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, seqLen_seqLen_tmp_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    ptr_left_matrix_send = &XQ_tile;

    ptr_right_matrix_send = &seqLen_dim_tmp;
    ptr_right_matrix_recv = &XK_tile;

    ptr_out_matrix = &seqLen_seqLen_tmp;

    Mt = seq_len_p_pe;
    Kt = head_dim_p_pe;  // wyn: per-head score contracts head_dim (full-row reduce: head_dim_p_pe*P)
    Nt = seq_len_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = true;

    matmul_T_compute();
}

fn softmax_score() void {

    // wyn: DEBUG — snapshot head-0 raw score before alpha/mask/softmax modify it
    if (head_idx == 0) {
        @fmovh(score_dbg_dsd, score_dsd);
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_score);

    @load_to_dsr(comp_dest_dsr_1, score_dsd);
    @load_to_dsr(comp_src0_dsr_1, score_dsd);
    @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, alpha);

    // wyn: causal mask. score is laid out [key_local outer, query_local inner]; this PE holds
    // key block px and query block py, so global key = px*sp+kl, global query = py*sp+ql.
    // Set future positions (key > query) to neg_inf so they contribute 0 after softmax.
    for (@range(i16, seq_len_p_pe)) |kl| {
        for (@range(i16, seq_len_p_pe)) |ql| {
            if (px * seq_len_p_pe + kl > py * seq_len_p_pe + ql) {
                score[kl * seq_len_p_pe + ql] = neg_inf;
            }
        }
    }
    // wyn: end

    @load_to_dsr(comp_dest_dsr_1, local_max_dsd, .{ .save_address = false});
    @fmovh(comp_dest_dsr_1, 0.0); // Clearing
    @load_to_dsr(comp_src0_dsr_1, local_max_dsd, .{ .save_address = false});
    @load_to_dsr(comp_src1_dsr_1, seqLen_dsd_1, .{ .save_address = true});
    for (@range(i16, seq_len_p_pe)) |i| {
        @fmaxh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);
    }

    comm_mod.mv_allreduce_max_x(ptr_local_max); // Global max in local_max

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_score);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true});
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_1, .{ .save_address = true});
    @load_to_dsr(comp_src1_dsr_1, local_max_dsd, .{ .save_address = false});
    for (@range(i16, seq_len_p_pe)) |i| {
        @fsubh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);
    }
    
    for (@range(i16, seq_len_p_pe * seq_len_p_pe)) |i| {
        seqLen_seqLen_tmp[i] = math_lib.exp_f16(score[i]);
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_seqLen_seqLen_tmp);

    @load_to_dsr(comp_dest_dsr_1, local_sum_dsd, .{ .save_address = false});
    @fmovh(comp_dest_dsr_1, 0.0); // Clearing
    @load_to_dsr(comp_src0_dsr_1, local_sum_dsd, .{ .save_address = false});
    @load_to_dsr(comp_src1_dsr_1, seqLen_dsd_1, .{ .save_address = true});
    for (@range(i16, seq_len_p_pe)) |i| {
        @faddh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);
    }

    comm_mod.mv_allreduce_add_x(ptr_local_sum);

    for (@range(i16, seq_len_p_pe)) |i| {
        ptr_local_sum[i] = 1.0 / ptr_local_sum[i];
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_score);
    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_seqLen_seqLen_tmp);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true});
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_2, .{ .save_address = true});
    @load_to_dsr(comp_src1_dsr_1, local_sum_dsd, .{ .save_address = false});
    for (@range(i16, seq_len_p_pe)) |i| {
        @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);
    }

    prefill_struct();
}

fn output_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, output_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    // wyn: DEBUG snapshot the two operands of output = probs @ XV, exactly as consumed.
    if (head_idx == 0) {
        for (@range(i16, seq_len_p_pe * seq_len_p_pe)) |i| {
            probs_dbg[i] = score[i];
        }
        for (@range(i16, seq_len_p_pe * head_dim_p_pe)) |i| {
            xv_dbg[i] = XV_tile[i];
        }
    }

    ptr_left_matrix_send = &seqLen_seqLen_tmp;
    ptr_left_matrix_recv = &score;

    ptr_right_matrix_send = &seqLen_dim_tmp;
    ptr_right_matrix_recv = &XV_tile;

    ptr_out_matrix = &output_tile;

    Mt = seq_len_p_pe;
    Kt = seq_len_p_pe;
    Nt = head_dim_p_pe;  // wyn: output_h is [seq, head_dim]

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    in_preshift = true;
    pre_remaining = offset_step;
    shift_round = 0;
    left_matrix_shift_callback();
}

fn h1_matmul() void {

    // wyn: per-head O-projection with ACCUMULATION. h1 += output_h @ Wo_h, where Wo_h is head
    // head_idx's [head_dim, dim] slice of O (head-major, offset head_idx*head_dim_p_pe*dim_p_pe).
    // Clear h1 only once (head 0); later heads accumulate on top via the matmul's fmach.
    if (head_idx == 0) {
        @load_to_dsr(comp_dest_dsr_1, h1_dsd);
        @fmovh(comp_dest_dsr_1, 0.0);
    }

    ptr_left_matrix_send = &seqLen_dim_tmp;
    ptr_left_matrix_recv = &output_tile;

    ptr_right_matrix_send = &dim_dim_tmp;
    ptr_right_matrix_recv = @ptrcast([*]f16, &O_weight_tile[head_idx * head_dim_p_pe * dim_p_pe]);

    ptr_out_matrix = &h1_tile;

    Mt = seq_len_p_pe;
    Kt = head_dim_p_pe;  // wyn: contract head_dim (output_h is [seq, head_dim])
    Nt = dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    in_preshift = true;
    pre_remaining = offset_step;
    shift_round = 0;
    left_matrix_shift_callback();
}

fn z_add() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, Z_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    @load_to_dsr(comp_src0_dsr_1, X_dsd);
    @load_to_dsr(comp_src1_dsr_1, h1_dsd);
    @faddh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);

    // wyn: snapshot the post-attention residual (resid_mid) before the FFN overwrites Z
    @fmovh(Z_mid_dsd, Z_dsd);

    prefill_struct();
}

fn rmsnorm_z() void {

    @load_to_dsr(comp_dest_dsr_2, seqLen_dim_tmp_dsd);
    @load_to_dsr(comp_src0_dsr_2, Z_dsd);
    @load_to_dsr(comp_src1_dsr_2, Z_dsd);
    @fmulh(comp_dest_dsr_2, comp_src0_dsr_2, comp_src1_dsr_2);

    // Clearing
    @load_to_dsr(comp_dest_dsr_2, local_sum_dsd, .{ .save_address = false });
    @fmovh(comp_dest_dsr_2, 0.0);

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_seqLen_dim_tmp);

    @load_to_dsr(comp_src0_dsr_2, local_sum_dsd, .{ .save_address = false });
    // wyn: was seqLen_dsd_2 (stale base -> garbage sum -> sqrt(neg)=NaN in ffn_only). Use
    // seqLen_dsd_1, which is freshly set to seqLen_dim_tmp above (mirrors rmsnorm_x).
    @load_to_dsr(comp_src1_dsr_2, seqLen_dsd_1, .{ .save_address = true });

    for (@range(i16, dim_p_pe)) |i| {
        @faddh(comp_dest_dsr_2, comp_src0_dsr_2, comp_src1_dsr_2);
    }

    comm_mod.mv_allreduce_add_x(ptr_local_sum);

    for (@range(i16, seq_len_p_pe)) |i| {
        sum = ptr_local_sum[i];
        // wyn: RMSNorm mean is over the full model dim, not the attention head_dim
        sum = sum / model_dim;
        // wyn: end
        ptr_local_sum[i] = 1.0 / math_lib.sqrt_f16(sum + eps);
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_Z_norm);
    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_Z);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true });
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_2, .{ .save_address = true });

    for (@range(i16, dim_p_pe)) |i| {
        // wyn: pre-FFN norm uses the post_attention_layernorm weight (W2), not W
        @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, W2_tile[i]);
        // wyn: end
    }

    seqLen_dsd_1 = @set_dsd_base_addr(seqLen_dsd_1, ptr_Z_norm);
    seqLen_dsd_2 = @set_dsd_base_addr(seqLen_dsd_2, ptr_Z_norm);

    @load_to_dsr(comp_dest_dsr_1, seqLen_dsd_1, .{ .save_address = true });
    @load_to_dsr(comp_src0_dsr_1, seqLen_dsd_2, .{ .save_address = true });

    // wyn: local_sum has only seq_len_p_pe entries; the old local_sum[i] over dim_p_pe read OOB
    // garbage (masked in the attention compile). seq_len_p_pe==1 here, so every dim shares one
    // norm factor — read it once and apply to all dims.
    var nf: f16 = ptr_local_sum[0];
    for (@range(i16, dim_p_pe)) |i| {
        @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, nf);
    }

    prefill_struct();
}

fn z1_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, z1_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    ptr_left_matrix_send = &seqLen_dim_tmp;
    ptr_left_matrix_recv = &Z_norm_tile;

    ptr_right_matrix_send = &dim_ffnDim_tmp;
    ptr_right_matrix_recv = &UP_weight_tile;

    ptr_out_matrix = &z1_tile;

    Mt = seq_len_p_pe;
    Kt = dim_p_pe;
    Nt = ffn_dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    in_preshift = true;
    pre_remaining = offset_step;
    shift_round = 0;
    left_matrix_shift_callback();
}

fn z2_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, z2_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    // wyn: OPEN QUESTION (13 Jul). This is structurally IDENTICAL to the xk_matmul bug --
    // it hardcodes Z_norm_tile as the buffer z1_matmul left the shifted Z in, but that is
    // only true when offset_step is even. By that reasoning the gate projection should be
    // wrong for odd-offset_step rows, yet the FFN validates at cos 0.986, which half-broken
    // rows cannot produce. So either the mechanism differs here or the FFN has a latent bug
    // the aggregate cosine hides. NOT changed until attention is fixed and understood --
    // check per-row FFN error before touching this.
    ptr_left_matrix_send = &seqLen_dim_tmp;
    ptr_left_matrix_recv = &Z_norm_tile;

    ptr_right_matrix_send = &dim_ffnDim_tmp;
    ptr_right_matrix_recv = &GATE_weight_tile;

    ptr_out_matrix = &z2_tile;

    Mt = seq_len_p_pe;
    Kt = dim_p_pe;
    Nt = ffn_dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    // left_matrix_shift_callback();
    matmul_compute();
}

fn silu_kernel(x: f16) f16 {
    // SiLU(x) = x * sigmoid(x) = x / (1 + e^-x)
    return x / (@as(f16, 1.0) + math_lib.exp_f16(@as(f16, -x)));
}

fn z3_comp() void {

    @map(silu_kernel, z2_dsd, z2_dsd);
    
    @load_to_dsr(comp_dest_dsr_1, z3_dsd);
    @load_to_dsr(comp_src0_dsr_1, z1_dsd);
    @load_to_dsr(comp_src1_dsr_1, z2_dsd);
    @fmulh(comp_dest_dsr_1, comp_src0_dsr_1, comp_src1_dsr_1);

    prefill_struct();
}

fn h2_matmul() void {

    // Clearing
    @load_to_dsr(comp_dest_dsr_1, h2_dsd);
    @fmovh(comp_dest_dsr_1, 0.0);

    ptr_left_matrix_send = &seqLen_ffnDim_tmp;
    ptr_left_matrix_recv = &z3_tile;

    ptr_right_matrix_send = &dim_ffnDim_tmp;
    ptr_right_matrix_recv = &DOWN_weight_tile;

    ptr_out_matrix = &h2_tile;

    Mt = seq_len_p_pe;
    Kt = ffn_dim_p_pe;
    Nt = dim_p_pe;

    left_matrix_dsd = @set_dsd_length(left_matrix_dsd, @bitcast(u16, Mt));
    right_matrix_dsd = @set_dsd_length(right_matrix_dsd, @bitcast(u16, Nt));

    out_matrix_dsd = @set_dsd_length(out_matrix_dsd, @bitcast(u16, Mt));

    is_T_matmul = false;

    left_dim_length = Mt * Kt;

    in_preshift = true;
    pre_remaining = offset_step;
    shift_round = 0;
    left_matrix_shift_callback();
}

fn add_result() void {
    @faddh(Z_dsd, Z_dsd, h2_dsd);
}

// Prefill pipeline state machine. Each stage advances `flag`, runs its kernel,
// and the kernel re-enters prefill_struct() on completion (directly or via the
// comm finish tasks), so the stages run in order without explicit chaining here.
var flag: i16 = 0;
fn prefill_struct() void {
    if (flag == 0) {
        if (ffn_only == 1) {
            // wyn: FFN-only (P=256). Input X is resid_mid; copy it into Z and jump straight to
            // the post-attention norm + FFN, skipping attention (flags 1-10). flag=12 mirrors the
            // flag==11 handler (flag+=1 then rmsnorm_z), so the FFN stages run unchanged.
            @fmovh(Z_dsd, X_dsd);
            flag = 12;
            rmsnorm_z();
        } else {
            flag += 1;
            rmsnorm_x();
        }
    } else if (flag == 1) {
        flag += 1;
        xq_matmul();
    } else if (flag == 2) {
        flag += 1;
        xk_matmul();
    } else if (flag == 3) {
        flag += 1;
        xv_matmul();
    } else if (flag == 4) {
        flag += 1;
        xq_rope();
    } else if (flag == 5) {
        flag += 1;
        xk_rope();
    } else if (flag == 6) {
        flag += 1;
        score_matmul();
    } else if (flag == 7) {
        flag += 1;
        softmax_score();
    } else if (flag == 8) {
        flag += 1;
        output_matmul();
    } else if (flag == 9) {
        flag += 1;
        h1_matmul();
    } else if (flag == 10) {
        // wyn: head-sequential loop. After head_idx's O-proj accumulate into h1, either start
        // the next head's attention, or (all heads done) proceed to the FFN. rmsnorm_x (flag 0)
        // ran once and X_norm is shared across heads.
        if (head_idx < n_heads - 1) {
            head_idx += 1;
            kv_head_idx = head_idx / group;
            flag = 2;          // re-enter at xq (mirrors the flag==1 handler: flag=2 while xq runs)
            xq_matmul();
        } else {
            head_idx = 0;      // reset for the next repeat / layer
            kv_head_idx = 0;
            flag += 1;         // -> 11
            z_add();
        }
    } else if (flag == 11) {
        flag += 1;
        rmsnorm_z();
    } else if (flag == 12) {
        flag += 1;
        z1_matmul();
    } else if (flag == 13) {
        flag += 1;
        z2_matmul();
    } else if (flag == 14) {
        flag += 1;
        z3_comp();
    } else if (flag == 15) {
        flag += 1;
        h2_matmul();
    } else {
        add_result();
        prefill_entry();
    }
}

// -------------------------------------------------------------------------- //
// ------------------------------ Entry Point ----------------------------- //
// -------------------------------------------------------------------------- //
var total_repeat_times: i16 = 1;
var total_warmup_times: i16 = 0;

var repeat_times: i16 = 0; // Start from 0

fn prefill_host(total_warmup_times_: i16, total_repeat_times_: i16) void {
    total_repeat_times = total_repeat_times_;
    total_warmup_times = total_warmup_times_;

    repeat_times = 0;

    prefill_entry();
}

fn prefill_entry() void {
    // Run (total_warmup_times + total_repeat_times) times; only the last `total_repeat_times` iterations are timed
    if (repeat_times == total_repeat_times + total_warmup_times) {
        exit();
    } else {
        if (repeat_times == total_warmup_times) {
            timestamp.get_timestamp(&tscRefBuffer);
            timestamp.get_timestamp(&tscStartBuffer);
        }
        
        repeat_times += 1;
        flag = 0;
        prefill_struct();
    }
}

fn exit() void {
    timestamp.get_timestamp(&tscEndBuffer);
    timestamp.disable_tsc();

    f_reference_timestamps();
    f_memcpy_timestamps();
    sys_mod.unblock_cmd_stream();
}

fn f_memcpy_timestamps() void {
    var lo_ : u16 = 0;
    var hi_ : u16 = 0;
    var word : u32 = 0;

    lo_ = tscStartBuffer[0];
    hi_ = tscStartBuffer[1];
    time_buf_f32[0] = @bitcast(f32, (@as(u32,hi_) << @as(u16,16)) | @as(u32, lo_) );

    lo_ = tscStartBuffer[2];
    hi_ = tscEndBuffer[0];
    time_buf_f32[1] = @bitcast(f32, (@as(u32,hi_) << @as(u16,16)) | @as(u32, lo_) );

    lo_ = tscEndBuffer[1];
    hi_ = tscEndBuffer[2];
    time_buf_f32[2] = @bitcast(f32, (@as(u32,hi_) << @as(u16,16)) | @as(u32, lo_) );
}

fn f_reference_timestamps() void {
    var lo_ : u16 = 0;
    var hi_ : u16 = 0;

    lo_ = tscRefBuffer[0];
    hi_ = tscRefBuffer[1];
    time_ref_f32[0] = @bitcast(f32, (@as(u32,hi_) << @as(u16,16)) | @as(u32, lo_) );

    lo_ = tscRefBuffer[2];
    hi_ = 0;
    time_ref_f32[1] = @bitcast(f32, (@as(u32,hi_) << @as(u16,16)) | @as(u32, lo_) );
}

comptime {
    @export_symbol(ptr_time_memcpy, "time_memcpy");
    @export_symbol(ptr_time_ref, "time_ref");
}

comptime {
    @bind_local_task(two_hop_comm_finish, two_hop_comm_finish_id);
    @bind_local_task(left_matrix_finish, left_matrix_finish_id);
    @bind_local_task(right_matrix_finish, right_matrix_finish_id);
    @bind_local_task(next_step, next_step_id);

    @block(two_hop_comm_finish_id);
    @block(left_matrix_finish_id);
    @block(right_matrix_finish_id);
    @block(next_step_id);
}

comptime {
    @export_symbol(ptr_X, "X");
    @export_symbol(ptr_W, "W");
    // wyn: post-attention norm weight (rmsnorm_z)
    @export_symbol(ptr_W2, "W2");
    // wyn: end
    @export_symbol(ptr_Q_weight, "Q_weight");
    @export_symbol(ptr_K_weight, "K_weight");
    @export_symbol(ptr_V_weight, "V_weight");
    @export_symbol(ptr_freqs_sin, "freqs_sin");
    @export_symbol(ptr_freqs_cos, "freqs_cos");
    @export_symbol(ptr_O_weight, "O_weight");
    @export_symbol(ptr_UP_weight, "UP_weight");
    @export_symbol(ptr_GATE_weight, "GATE_weight");
    @export_symbol(ptr_DOWN_weight, "DOWN_weight");
    // wyn: export Z
    @export_symbol(ptr_Z, "Z");   // layer output after all processing
    @export_symbol(ptr_Z_mid, "Z_mid");   // wyn: post-attention residual (resid_mid)
    @export_symbol(ptr_score_dbg, "score_dbg");   // wyn: DEBUG head-0 raw score
    @export_symbol(ptr_xq_proj_dbg, "xq_proj_dbg");   // wyn: DEBUG head-0 XQ pre-rope
    @export_symbol(ptr_xq_rope_dbg, "xq_rope_dbg");   // wyn: DEBUG head-0 XQ post-rope
    @export_symbol(ptr_X_norm_backup, "X_norm_dbg");  // wyn: DEBUG pristine rmsnorm_x output
    @export_symbol(ptr_xk_trace, "xk_trace");     // wyn: DEBUG head-0 per-step XK tile
    @export_symbol(ptr_probs_dbg, "probs_dbg");   // wyn: DEBUG head-0 post-softmax probs
    @export_symbol(ptr_xv_dbg, "xv_dbg");         // wyn: DEBUG head-0 XV as output_matmul sees it
    // wyn: end
    @export_symbol(init_task);
    @export_symbol(prefill_host);
}
