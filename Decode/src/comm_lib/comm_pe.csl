param P: i16;
param bsz: i16;
param dim_p_pe: i16;
param seq_len_p_pe: i16;
param ffn_dim_p_pe: i16;

param pe_num_p_group: i16;
param root_1st_phase: i16;
param root_2nd_phase: i16;

// Routing is computed at RUNTIME from each PE's own coordinate (see init() and
// reconfig_allreduce_axis() below), instead of being passed in as per-PE comptime
// route structs from the layout. This keeps comm_pe.csl's comptime params identical
// on every PE, so the module is no longer specialized per coordinate.
param reduce_1st_color_0: color;
param reduce_1st_color_1: color;

param reduce_2nd_color_0: color;
param reduce_2nd_color_1: color;

param broadcast_color: color;

