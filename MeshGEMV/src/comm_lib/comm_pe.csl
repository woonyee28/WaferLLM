param P: i16;
param Mt: i16;
param Nt: i16;

const math = @import_module("<math>");

var px: i16 = 0;
var py: i16 = 0;

param pe_num_group: i16;
param root_1st_phase: i16;
param root_2nd_phase: i16;

var is_last_py: bool = false;

param comm_params;

// For broadcast in y-axis
const c_down_recv: color = comm_params.c_down_recv;
const c_down_send: color = comm_params.c_down_send;
const c_up_recv: color = comm_params.c_up_recv;
const c_up_send: color = comm_params.c_up_send;

const up_bd_color: color = comm_params.up_bd_color;
const down_bd_color: color = comm_params.down_bd_color;

const c_y_up_reduce_send: color = comm_params.c_y_up_reduce_send;
const c_y_up_reduce_recv: color = comm_params.c_y_up_reduce_recv;

const c_y_down_reduce_send: color = comm_params.c_y_down_reduce_send;
const c_y_down_reduce_recv: color = comm_params.c_y_down_reduce_recv;

const reduce_1st_up_recv_queue_id = @get_input_queue(2);
const reduce_1st_up_send_queue_id = @get_output_queue(2);
const reduce_1st_down_recv_queue_id = @get_input_queue(3);
const reduce_1st_down_send_queue_id = @get_output_queue(3);

const reduce_2nd_up_recv_queue_id = @get_input_queue(4);
const reduce_2nd_up_send_queue_id = @get_output_queue(4);
const reduce_2nd_down_recv_queue_id = @get_input_queue(5);
const reduce_2nd_down_send_queue_id = @get_output_queue(5);

const broadcast_up_recv_queue_id = @get_input_queue(6);
const broadcast_up_send_queue_id = @get_output_queue(6);
const broadcast_down_recv_queue_id = @get_input_queue(7);
const broadcast_down_send_queue_id = @get_output_queue(7);

const mv_down_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = reduce_1st_down_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const mv_down_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = reduce_1st_down_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const mv_up_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = reduce_1st_up_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const mv_up_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = reduce_1st_up_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const up_reduce_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = reduce_2nd_up_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const up_reduce_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = reduce_2nd_up_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const down_reduce_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = reduce_2nd_down_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const down_reduce_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = reduce_2nd_down_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

// For directly broadcast in y-axis
const up_bd_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = broadcast_up_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const up_bd_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = broadcast_up_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const down_bd_send = @get_dsd(fabout_dsd, .{
    .extent = Nt,
    .output_queue = broadcast_down_send_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const down_bd_recv = @get_dsd(fabin_dsd, .{
    .extent = Nt,
    .input_queue = broadcast_down_recv_queue_id,
    .simd_mode = .{ .simd_max = true },
});

const dummy = @zeros([1]f16);

var vector_buf_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{Nt} -> dummy[i] });
const vector_buf_dsr = @get_dsr(dsr_src1, 2);

var is_group_first_py: bool = false;
var is_group_last_py: bool = false;
var is_group_root_py: bool = false;

var is_top_half_py: bool = false;

var is_first_group_py: bool = false;
var is_last_group_py: bool = false;

fn init_(_px: i16, _py: i16) void {
    px = _px;
    py = _py;

    if (py == P-1) {
        is_last_py = true;
    }

    var remainder_y: i16 = py - @as(i16, math.floor_f16(@as(f16, py) / @as(f16, pe_num_group))) * pe_num_group;

    if (remainder_y == 0) {
        is_group_first_py = true;
    }
    
    if (remainder_y == pe_num_group - 1) {
        is_group_last_py = true;
    } 
    
    if (remainder_y == root_1st_phase) {
        is_group_root_py = true;
    } else if (remainder_y < root_1st_phase) {
        is_top_half_py = true;
    }

    if (py < pe_num_group) {
        is_first_group_py = true;
    } 
    
    if (py > P - pe_num_group - 1) {
        is_last_group_py = true;
    }
}

fn two_tree_allreduce_y(vector_buf_ptr: [*]f16) void {

    vector_buf_dsd = @set_dsd_base_addr(vector_buf_dsd, vector_buf_ptr);
    @load_to_dsr(vector_buf_dsr, vector_buf_dsd);

    // The first phase reduce
    if (is_group_root_py) {
        if (!is_group_last_py) {
            @faddh(vector_buf_dsd, mv_up_recv, vector_buf_dsr);
        } 
        @faddh(vector_buf_dsd, mv_down_recv, vector_buf_dsr);
    } else if (is_group_first_py) {
        @fmovh(mv_down_send, vector_buf_dsr);
    } else if (is_group_last_py) {
        @fmovh(mv_up_send, vector_buf_dsr);
    } else {
        if (is_top_half_py) {
            @faddh(mv_down_send, mv_down_recv, vector_buf_dsr);
        } else {
            @faddh(mv_up_send, mv_up_recv, vector_buf_dsr);
        }
    }

    // The second phase reduce
    if (py == root_2nd_phase) {
        if (!is_last_group_py) {
            @faddh(vector_buf_dsd, up_reduce_recv, vector_buf_dsr);
        }
        @faddh(vector_buf_dsd, down_reduce_recv, vector_buf_dsd);
    } else if (is_group_root_py) {
        if (is_first_group_py) {
            @fmovh(down_reduce_send, vector_buf_dsr);
        } else if (is_last_group_py) {
            @fmovh(up_reduce_send, vector_buf_dsr);
        } else {
            if (py < root_2nd_phase) {
                @faddh(down_reduce_send, down_reduce_recv, vector_buf_dsr);
            } else {
                @faddh(up_reduce_send, up_reduce_recv, vector_buf_dsr);
            }
        }
    }

    // Broadcast
    if (py == root_2nd_phase) {
        @fmovh(up_bd_send, vector_buf_dsr);
        if (!is_last_py) {
            @fmovh(down_bd_send, vector_buf_dsr);
        }
    } else {
        if (py < root_2nd_phase) {
            @fmovh(vector_buf_dsd, up_bd_recv);
        } else {
            @fmovh(vector_buf_dsd, down_bd_recv);
        }
    }

}

comptime {
    @block(reduce_1st_down_recv_queue_id);
    @block(reduce_1st_up_recv_queue_id);

    @initialize_queue(reduce_1st_up_recv_queue_id, .{.color = c_up_recv});
    @initialize_queue(reduce_1st_up_send_queue_id, .{.color = c_up_send});
    @initialize_queue(reduce_1st_down_recv_queue_id, .{.color = c_down_recv});
    @initialize_queue(reduce_1st_down_send_queue_id, .{.color = c_down_send});
    @initialize_queue(reduce_2nd_up_recv_queue_id, .{.color = c_y_up_reduce_recv});
    @initialize_queue(reduce_2nd_up_send_queue_id, .{.color = c_y_up_reduce_send});
    @initialize_queue(reduce_2nd_down_recv_queue_id, .{.color = c_y_down_reduce_recv});
    @initialize_queue(reduce_2nd_down_send_queue_id, .{.color = c_y_down_reduce_send});
    @initialize_queue(broadcast_up_recv_queue_id, .{.color = up_bd_color});
    @initialize_queue(broadcast_up_send_queue_id, .{.color = up_bd_color});
    @initialize_queue(broadcast_down_recv_queue_id, .{.color = down_bd_color});
    @initialize_queue(broadcast_down_send_queue_id, .{.color = down_bd_color});
}